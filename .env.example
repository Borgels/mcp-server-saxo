# Environment: sim (default) or live
SAXO_ENVIRONMENT=sim

# Bearer token (required). For SIM you can paste a 24-hour token from
# https://developer.saxobank.com. For LIVE supply tokens issued by your OAuth
# flow, or run `npm run auth -- --env live` to generate them.
SAXO_ACCESS_TOKEN=

# Optional refresh token + app credentials. If all three are set the server
# will refresh the access token automatically when Saxo returns 401.
SAXO_REFRESH_TOKEN=
SAXO_TOKEN_EXPIRES_AT=
SAXO_APP_KEY=
SAXO_APP_SECRET=
SAXO_REDIRECT_URI=http://localhost:8765/callback

# Client behaviour
SAXO_TIMEOUT_MS=30000

# LIVE trading safety. Writes against gateway.saxobank.com/openapi require
# SAXO_ENABLE_LIVE_TRADING=true on top of any policy.json restrictions.
SAXO_ENABLE_LIVE_TRADING=false
SAXO_POLICY_PATH=
SAXO_AUDIT_LOG=

# MCP HTTP transport
MCP_HTTP_HOST=127.0.0.1
MCP_MAX_BODY_BYTES=10485760
MCP_ALLOWED_ORIGINS=
MCP_ALLOW_ANY_ORIGIN=false
MCP_HTTP_TOKEN=
